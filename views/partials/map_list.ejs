<script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>

<h3>所有數據</h3>
<div class="form-group" style="display: flex;
flex-direction: column;
    align-items: center;">
    <input type="text" name="school_name" id="school_input" placeholder="检索" required>
    <div id="results_list"></div>
</div>

<h3>標簽</h3>
<div style="display: flex;     flex-direction: row;
    justify-content: center;">
    <div class="div">
        <h3>填寫類型</h3>
        <a href="/map">全部</a><br>
        <a href="?inputType=受害者本人">受害者本人</a><br>
        <a href="?inputType=受害者的代理人">受害者的代理人</a>
    </div>
</div>

<div id="data-container" style="
display: flex;
flex-direction: column;
    align-items: center;"></div>

<script>
    const queryString = window.location.search;
    const urlParams = new URLSearchParams(queryString);
    const inputType = urlParams.get('inputType')
    
    async function loadData() {
        try {
            // 2. 獲取數據
            const response = await axios.get(window.API_URL);
            
            const rawData = response.data.data;

            const container = document.getElementById('data-container');

            // 3. 循環處理
            rawData.forEach(item => {
                if(item.inputType != inputType && inputType) return;

                const card = document.createElement('details');
                card.className = 'div';
                card.style.width = '100%'

                let scandalHtml = item.scandal ? `<div class="scandal">⚠️ ${item.scandal}</div>` : '';

                card.innerHTML = `
                    <summary><h2>${item.name}</h2><br><small>填寫類型：${item.inputType}</small></summary>
                    <div class="div">
                        <p><strong>負責人：</strong>${item.HMaster}</p>
                        <p><strong>省份：</strong>${item.province}</p>
                        <p><strong>鄉、鎮：</strong>${item.prov}</p>
                        <p><strong>地址：</strong>${item.addr}</p>
                        <hr>
                        ${scandalHtml}
                        <div class="contact"><strong>聯繫方式：</strong>\n${item.contact}</div>
                    </div>
                `;

                container.appendChild(card);
            });
        } catch (error) {
            console.error('獲取數據失敗:', error);
            document.getElementById('data-container').innerHTML = '<p>數據加載失敗</p>';
        }
    }

    // 執行函數
    loadData();
</script>