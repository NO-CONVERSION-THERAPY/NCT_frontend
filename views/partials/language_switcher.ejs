<div class="language-switcher" aria-label="<%= t('common.language') %>" data-language-switcher>
    <% /* 这里不直接写死语言名称，按钮标签统一来自服务端生成的 languageOptions。 */ %>
    <button
        type="button"
        class="language-switcher__toggle"
        data-language-toggle
        aria-label="<%= t('common.language') %>"
        aria-controls="language-switcher-group"
        aria-expanded="false"
    >
        <span class="language-switcher__icon" aria-hidden="true">🌏</span>
    </button>
    <div
        id="language-switcher-group"
        class="language-switcher__group"
        role="group"
        aria-label="<%= t('common.language') %>"
    >
        <% languageOptions.forEach((option) => { %>
            <button
                type="button"
                class="language-switcher__button <%= option.code === lang ? 'is-active' : '' %>"
                data-lang-option="<%= option.code %>"
                aria-pressed="<%= option.code === lang ? 'true' : 'false' %>"
            >
                <%= option.label %>
            </button>
        <% }) %>
    </div>
</div>
