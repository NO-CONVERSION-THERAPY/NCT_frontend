<!DOCTYPE html>
<html lang="<%= lang %>">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <meta name="color-scheme" content="light dark">
        <% if (typeof pageRobots !== 'undefined' && pageRobots) { %>
        <meta name="robots" content="<%= pageRobots %>">
        <% } %>
        <title><%= t('common.siteName') %></title>
        <link rel="stylesheet" href="/css/index.css?v=<%= assetVersion %>">
        <script>
            window.APP_LANG = "<%= lang %>";
            window.I18N = <%- JSON.stringify(clientMessages) %>;
        </script>
    </head>
    <body class="submit-page">
        <div class="hero">
            <h1><%= t('submitSuccess.title') %></h1>
            <p>
                <%= t('submitSuccess.message') %>
            </p>
            <% if (showSubmissionDiagnostics && submissionDiagnostics) { %>
                <div class="submit-status-card">
                    <h2><%= t('submitStatus.title') %></h2>
                    <p><strong><%= t('submitStatus.mode') %></strong> <%= submissionDiagnostics.attemptedTargets.map((target) => target.label).join(' / ') %></p>
                    <p><strong><%= t('submitStatus.successfulTargets') %></strong> <%= submissionDiagnostics.successfulTargets.length > 0 ? submissionDiagnostics.successfulTargets.map((target) => target.label).join(' / ') : t('submitStatus.none') %></p>
                    <p><strong><%= t('submitStatus.failedTargets') %></strong> <%= submissionDiagnostics.failedTargets.length > 0 ? submissionDiagnostics.failedTargets.map((target) => target.label).join(' / ') : t('submitStatus.none') %></p>
                    <% if (submissionDiagnostics.failedTargets.length > 0) { %>
                        <div class="submit-status-card__errors">
                            <% submissionDiagnostics.failedTargets.forEach((target) => { %>
                                <p><strong><%= target.label %></strong> <%= t('submitStatus.error') %><%= target.error %></p>
                            <% }) %>
                        </div>
                    <% } %>
                </div>
            <% } %>
            <div class="hero__actions submit-page__actions">
                <a href="/" class="btn"><%= t('submitSuccess.backHome') %></a>
                <a href="https://github.com/HosinoEJ/No-Torsion" class="btn"><%= t('submitSuccess.petition') %></a>
            </div>
        </div>

        <style>
            .submit-status-card {
                width: min(100%, 760px);
                margin: 1.5rem auto 0;
                padding: 1rem 1.15rem;
                border: 1px solid var(--panel-border);
                border-radius: 16px;
                background: var(--card-bg);
                box-shadow: var(--shadow-soft);
                box-sizing: border-box;
                text-align: left;
                overflow-wrap: anywhere;
            }
            .submit-status-card h2 {
                margin-top: 0;
            }
            .submit-status-card p {
                overflow-wrap: anywhere;
            }
            .submit-status-card p:last-child {
                margin-bottom: 0;
            }
            .submit-status-card__errors {
                margin-top: 0.8rem;
                color: var(--text-muted);
            }
        </style>
        <%- include('partials/foot') %>
    </body>
</html>
