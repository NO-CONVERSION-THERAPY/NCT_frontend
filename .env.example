# No-Torsion root is now a frontend-only Vite + React site.
# Legacy Express / EJS configuration has been moved to `old/.env.example`.

# Deployment mode:
# - api-only: browse public JSON data only, no form submission
# - hono: keep the static frontend, but send the "fill form" entry to nct-api-sql-sub
VITE_NO_TORSION_DEPLOY_MODE="api-only"

# Public JSON dataset URL.
# In direct mode this is typically the root public dataset of nct-api-sql.
# Example: https://api.example.com/
VITE_NCT_API_SQL_PUBLIC_DATA_URL="/content/map-data.json"

# Standalone Hono form page hosted by nct-api-sql-sub.
# Only used when VITE_NO_TORSION_DEPLOY_MODE="hono".
# Example: https://sub.example.com/no-torsion/form
VITE_NCT_SUB_FORM_URL=""

# Optional build-time snapshot refresh source.
# When omitted, the build reuses the checked-in public/content/map-data.json snapshot.
PUBLIC_MAP_DATA_SNAPSHOT_SOURCE_URL=""
