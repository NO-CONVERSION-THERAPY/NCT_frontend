<%- include('partials/head') %>
<body>
    <a href="/" class="page-back-link">← <%= t('navigation.home') %></a>
    <main class="about-page privacy-page">
        <h1><%= t('privacy.title') %></h1>
        <p class="privacy-page__intro"><%= t('privacy.intro') %></p>

        <section class="div">
            <h3><%= t('privacy.sections.summary') %></h3>
            <p><%= t('privacy.summary') %></p>
        </section>

        <section class="div">
            <h3><%= t('privacy.sections.cookie') %></h3>
            <p><%= t('privacy.cookieIntro') %></p>
            <dl class="privacy-cookie-list">
                <div class="privacy-cookie-list__row">
                    <dt><%= t('privacy.cookieFields.name') %></dt>
                    <dd><code>lang</code></dd>
                </div>
                <div class="privacy-cookie-list__row">
                    <dt><%= t('privacy.cookieFields.purpose') %></dt>
                    <dd><%= t('privacy.cookieValues.purpose') %></dd>
                </div>
                <div class="privacy-cookie-list__row">
                    <dt><%= t('privacy.cookieFields.trigger') %></dt>
                    <dd><%= t('privacy.cookieValues.trigger') %></dd>
                </div>
                <div class="privacy-cookie-list__row">
                    <dt><%= t('privacy.cookieFields.retention') %></dt>
                    <dd><%= t('privacy.cookieValues.retention') %></dd>
                </div>
                <div class="privacy-cookie-list__row">
                    <dt><%= t('privacy.cookieFields.scope') %></dt>
                    <dd><%= t('privacy.cookieValues.scope') %></dd>
                </div>
                <div class="privacy-cookie-list__row">
                    <dt><%= t('privacy.cookieFields.attributes') %></dt>
                    <dd><%= t('privacy.cookieValues.attributes') %></dd>
                </div>
            </dl>
        </section>

        <section class="div">
            <h3><%= t('privacy.sections.manage') %></h3>
            <p><%= t('privacy.manageBody') %></p>
            <p><%= t('privacy.manageNote') %></p>
        </section>

        <section class="div">
            <h3><%= t('privacy.sections.contact') %></h3>
            <p><%= t('privacy.contactBody') %></p>
            <p class="privacy-page__contact"><a href="mailto:notorsion@hosinoneko.me">notorsion@hosinoneko.me</a></p>
        </section>
    </main>

    <%- include('partials/foot') %>
</body>
</html>
